-- @id: Q56
-- @target: PUSH-002
-- @severity: warning
-- @scenario: CTE + 多层联接
WITH cust_stats AS (
  SELECT customer_id, COUNT(*) AS cnt, SUM(amount) AS total
  FROM payment
  GROUP BY customer_id
)
SELECT c.first_name, c.last_name, cs.cnt, cs.total
FROM customer c
JOIN cust_stats cs ON c.customer_id = cs.customer_id
WHERE cs.total > 30
LIMIT 20;

Limit  (cost=442.98..451.17 rows=20 width=53) (actual time=10.690..12.390 rows=20 loops=1)
  ->  Nested Loop  (cost=442.98..688.18 rows=599 width=53) (actual time=10.687..12.384 rows=20 loops=1)
        ->  HashAggregate  (cost=442.98..450.47 rows=599 width=82) (actual time=10.654..10.682 rows=20 loops=1)
              Group By Key: payment.customer_id
              Filter: (sum(payment.amount) > 30::numeric)
              ->  Partition Iterator  (cost=0.00..282.49 rows=16049 width=10) (actual time=0.017..4.339 rows=16049 loops=1)
                    Iterations: 7
                    ->  Partitioned Seq Scan on payment  (cost=0.00..282.49 rows=16049 width=10) (actual time=0.060..2.413 rows=16049 loops=7)
                          Selected Partitions:  1..7
        ->  Index Scan using customer_pkey on customer c  (cost=0.00..0.38 rows=1 width=17) (actual time=1.661..1.669 rows=20 loops=20)
              Index Cond: (customer_id = payment.customer_id)
Total runtime: 12.642 ms

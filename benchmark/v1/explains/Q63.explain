-- @id: Q63
-- @target: SUBQ-001
-- @severity: warning
-- @scenario: payment 主查询 + 相关子查询(嵌套两层)
SELECT p.payment_id, p.amount,
       (SELECT SUM(amount) FROM payment p2 WHERE p2.customer_id = p.customer_id AND p2.payment_date <= p.payment_date) AS running_total
FROM payment p
WHERE p.amount > 5.00
LIMIT 10;


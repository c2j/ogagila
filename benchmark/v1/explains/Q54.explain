-- @id: Q54
-- @target: PUSH-002
-- @severity: warning
-- @scenario: 复杂查询产生多层 Streaming 节点
SELECT f.title, COUNT(r.rental_id) AS cnt
FROM film f
JOIN inventory i ON f.film_id = i.film_id
JOIN rental r ON i.inventory_id = r.inventory_id
JOIN payment p ON r.rental_id = p.rental_id
WHERE f.rating = 'PG'
GROUP BY f.title
ORDER BY cnt DESC
LIMIT 20;

Limit  (cost=1035.82..1035.87 rows=20 width=27) (actual time=24.841..24.845 rows=20 loops=1)
  ->  Sort  (cost=1035.82..1036.30 rows=194 width=27) (actual time=24.837..24.839 rows=20 loops=1)
        Sort Key: (count(r.rental_id)) DESC
        Sort Method: top-N heapsort  Memory: 27kB

-- @id: Q76
-- @target: DIST-001
-- @severity: info
-- @scenario: rental 无分布键提示
SELECT r.rental_id, i.film_id
FROM rental r
JOIN inventory i ON r.inventory_id = i.inventory_id
WHERE r.rental_date >= '2022-06-01'
LIMIT 20;


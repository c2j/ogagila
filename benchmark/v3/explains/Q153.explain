-- @id: Q153
-- @target: SKEW-001
-- @severity: warning
-- @scenario: payment 表 customer_id 倾斜(Top 客户消费笔数)
SELECT customer_id, COUNT(*) AS cnt, SUM(amount) AS total
FROM payment
GROUP BY customer_id
ORDER BY cnt DESC
LIMIT 5;


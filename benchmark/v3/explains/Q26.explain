-- @id: Q26
-- @target: MEM-001
-- @severity: warning
-- @scenario: GROUP BY + ORDER BY 组合排序
SET work_mem = '128kB';
SELECT customer_id, COUNT(*) AS cnt, SUM(amount) AS total
FROM payment
GROUP BY customer_id
ORDER BY total DESC
LIMIT 20;
RESET work_mem;


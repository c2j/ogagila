        Hash Cond: (r.inventory_id = i.inventory_id)
        ->  Hash Join  (cost=453.55..1481.97 rows=3957 width=14) (actual time=6.319..18.296 rows=3957 loops=1)
              Hash Cond: (p.customer_id = c.customer_id)
              ->  Hash Join  (cost=423.08..1287.09 rows=3957 width=12) (actual time=5.837..15.386 rows=3957 loops=1)
                    Hash Cond: (r.rental_id = p.rental_id)

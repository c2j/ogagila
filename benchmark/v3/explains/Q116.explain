-- @id: Q116
-- @target: GEN-001
-- @severity: info
-- @scenario: LATERAL 取前 N 个 actor
SELECT f.film_id, f.title, a.actor_id, a.first_name
FROM film f
CROSS JOIN LATERAL (
    SELECT fa.actor_id, ac.first_name
    FROM film_actor fa
    JOIN actor ac ON fa.actor_id = ac.actor_id
    WHERE fa.film_id = f.film_id
    ORDER BY fa.actor_id
    LIMIT 3
) a
ORDER BY f.film_id;


-- @id: Q164
-- @target: SCAN-004
-- @severity: warning
-- @scenario: 表达式索引(LOWER 包装,无索引会全表扫)
CREATE INDEX IF NOT EXISTS idx_customer_email_lower ON customer (LOWER(email));
SELECT * FROM customer WHERE LOWER(email) LIKE '%@example.org';


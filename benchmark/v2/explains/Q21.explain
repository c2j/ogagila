  Hash Cond: (i.film_id = f.film_id)
  ->  Hash Join  (cost=627.63..1853.45 rows=3957 width=14) (actual time=11.449..23.913 rows=3957 loops=1)
        Hash Cond: (r.inventory_id = i.inventory_id)
        ->  Hash Join  (cost=453.55..1481.97 rows=3957 width=14) (actual time=9.453..19.367 rows=3957 loops=1)
              Hash Cond: (p.customer_id = c.customer_id)
              ->  Hash Join  (cost=423.08..1287.09 rows=3957 width=12) (actual time=8.633..16.717 rows=3957 loops=1)

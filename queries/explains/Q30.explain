        ->  Hash Join  (cost=798.18..1522.02 rows=16053 width=19) (actual time=9.344..35.445 rows=16049 loops=1)
              Hash Cond: (r.inventory_id = i.inventory_id)
              ->  Hash Join  (cost=524.62..1027.78 rows=16049 width=8) (actual time=5.038..21.193 rows=16049 loops=1)
                    Hash Cond: (p.rental_id = r.rental_id)

        Hash Cond: (r.inventory_id = i.inventory_id)
        ->  Hash Join  (cost=484.03..1520.45 rows=3957 width=14) (actual time=2.027..5.959 rows=3957 loops=1)
              Hash Cond: (p.customer_id = c.customer_id)
              ->  Hash Join  (cost=423.08..1287.09 rows=3957 width=12) (actual time=1.882..5.088 rows=3957 loops=1)
                    Hash Cond: (r.rental_id = p.rental_id)
